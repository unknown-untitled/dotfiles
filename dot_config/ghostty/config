font-family = Iosevka
window-padding-x = 10
window-padding-y = 5
background = #181818
resize-overlay-duration = 1s 200ms
window-subtitle = working-directory

gtk-custom-css = ./style.css

shell-integration = detect
shell-integration-features = title, cursor, sudo
window-inherit-working-directory = false
window-decoration = server

gtk-titlebar = true
gtk-titlebar-style = native
gtk-wide-tabs = true
gtk-toolbar-style = raised

# tab location (top, bottom, hidden)
gtk-tabs-location = top