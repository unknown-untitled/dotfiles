font-family = Iosevka
window-padding-x = 10
window-padding-y = 5
background = #121212
resize-overlay-duration = 1s 200ms
window-subtitle = working-directory

gtk-custom-css = ./style.css

shell-integration = detect
shell-integration-features = title, cursor, sudo
window-inherit-working-directory = false
window-decoration = server

gtk-titlebar = true
#gtk-titlebar-style = tabs 
gtk-wide-tabs = true
gtk-toolbar-style = raised

# tab location (top, bottom, hidden)
gtk-tabs-location = top

background-opacity = 0.4

copy-on-select = clipboard
#clipboard-trim-trailing-spaces = true


#keybinds
keybind = ctrl+shift+d=new_split:right
keybind = ctrl+shift+e=new_split:down
keybind = ctrl+shift+x=close_surface
keybind = ctrl+tab=goto_split:next