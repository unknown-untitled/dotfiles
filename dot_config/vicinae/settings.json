// This configuration is merged with the default vicinae configuration file, which you can obtain by running the `vicinae config default` command.
// Every item defined in this file takes precedence over the values defined in the default config or any other imported file.
//
// You can make manual edits to this file, however you should keep in mind that this file may be written to by vicinae when a configuration change is made through the GUI.
// When that happens, any custom comments or formatting will be lost.
//
// If you want to maintain a configuration file with your own comments and formatting, you should create a separate file and add it to the 'imports' array.
//
// Learn more about configuration at https://docs.vicinae.com/config

{
   "$schema": "https://vicinae.com/schemas/config.json",
   "close_on_focus_loss": true,
   "font": {
      "normal": {
         "size": 12
      }
   },
   "theme": {
      "dark": {
         "name": "vicinae-dark",
         "icon_theme": "MoreWaita"
      }
   },
   "telemetry": {
      "system_info": false
   },
   "launcher_window": {
      "opacity": 0.97,
      "client_side_decorations": {
         "enabled": true
      }
   },
   "favorites": [
      "applications:v2rayn",
      "applications:com.mitchellh.ghostty",
      "applications:org.telegram",
      "applications:org.mozilla.firefox",
      "clipboard:history"
   ],
   "providers": {
      "browser-extension": {
         "enabled": false
      },
      "calculator": {
         "enabled": false
      },
      "clipboard": {
         "preferences": {
            "eraseOnStartup": true,
            "monitoring": true
         },
         "entrypoints": {
            "clear": {
               "enabled": false
            }
         }
      },
      "core": {
         "entrypoints": {
            "documentation": {
               "enabled": false
            },
            "keybind-settings": {
               "enabled": false
            },
            "list-extensions": {
               "enabled": false
            },
            "manage-fallback": {
               "enabled": false
            },
            "oauth-token-store": {
               "enabled": false
            },
            "open-default-config": {
               "enabled": false
            },
            "refresh-apps": {
               "enabled": false
            },
            "reload-scripts": {
               "enabled": false
            },
            "report-bug": {
               "enabled": false
            },
            "search-builtin-icons": {
               "enabled": false
            },
            "sponsor": {
               "enabled": false
            },
            "store": {
               "enabled": false
            }
         }
      },
      "developer": {
         "enabled": false
      },
      "files": {
         "enabled": false,
         "preferences": {
            "autoIndexing": false
         }
      },
      "font": {
         "enabled": false
      },
      "manage-shortcuts": {
         "enabled": false
      },
      "power": {
         "entrypoints": {
            "lock": {
               "alias": "swaylock"
            }
         }
      },
      "raycast-compat": {
         "enabled": false
      },
      "system": {
         "enabled": false,
         "entrypoints": {
            "browse-apps": {
               "enabled": true
            },
            "run": {
               "enabled": true
            }
         }
      },
      "theme": {
         "enabled": false
      },
      "wm": {
         "enabled": false
      }
   }
}