spawn-at-startup "sh" "-c" "waybar -c ~/.config/waybar/topbar -s ~/.config/waybar/topbar.css"
spawn-at-startup "sh" "-c" "swaybg -i ~/.config/wallpapers/m.jpg"
spawn-at-startup "swayosd-server"
spawn-at-startup "swaync"
spawn-at-startup "sh" "-c" "~/.local/bin/ironbar"
spawn-at-startup "~/.cargo/bin/wl-clip-persist" "--clipboard" "regular" "--max-size" "512000"
spawn-at-startup "vicinae" "server"
spawn-at-startup "veilad"